# Safe example actions: these commands only show notifications.
# Replace them with the volume, brightness, media, and workspace commands used by your desktop.

device = "auto"
edge_width = 0.10
tap_min_duration_ms = 80
swipe_min_distance = 0.02

[[sliders]]
zone = "left"
step = 0.04
up = ["notify-send", "edgepad", "volume-up"]
down = ["notify-send", "edgepad", "volume-down"]

[[gestures]]
zone = "left"
direction = "tap"
action = ["notify-send", "edgepad", "volume-mute"]

[[sliders]]
zone = "right"
step = 0.04
up = ["notify-send", "edgepad", "brightness-up"]
down = ["notify-send", "edgepad", "brightness-down"]

[[gestures]]
zone = "right"
direction = "tap"
action = ["notify-send", "edgepad", "brightness-toggle"]

[[gestures]]
zone = "top"
direction = "left"
action = ["notify-send", "edgepad", "media-previous"]

[[gestures]]
zone = "top"
direction = "right"
action = ["notify-send", "edgepad", "media-next"]

[[gestures]]
zone = "top"
direction = "tap"
action = ["notify-send", "edgepad", "media-play-pause"]

[[gestures]]
zone = "bottom"
direction = "left"
action = ["notify-send", "edgepad", "workspace-previous"]

[[gestures]]
zone = "bottom"
direction = "right"
action = ["notify-send", "edgepad", "workspace-next"]
